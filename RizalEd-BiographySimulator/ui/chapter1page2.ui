   <widget class="QTextEdit" name="rizal_sib1">
    <property name="enabled">
     <bool>false</bool>
    </property>
    <property name="geometry">
     <rect>
      <x>120</x>
      <y>210</y>
      <width>401</width>
      <height>451</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">
    QTextEdit {
        background: transparent;
        font-family: &quot;Times New Roman&quot;;
        font-size: 10pt;
        border: none;
    }
</string>
    </property>
    <property name="html">
     <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Times New Roman'; font-size:10pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt; color:#000000;&quot;&gt;Rizal was the seventh of eleven children, and his siblings played a significant role in his life. The siblings were:&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt; font-weight:600; color:#000000;&quot;&gt;1. Saturnina&lt;/span&gt;&lt;span style=&quot; font-size:12pt; color:#000000;&quot;&gt; – The eldest sibling, often called “Neneng,” who acted as a second mother to Jose.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt; font-weight:600; color:#000000;&quot;&gt;2. Paciano&lt;/span&gt;&lt;span style=&quot; font-size:12pt; color:#000000;&quot;&gt; – Jose's older brother and confidant. Paciano was deeply involved in the Filipino reform movement and influenced Jose’s political ideas.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt; font-weight:600; color:#000000;&quot;&gt;3. Narcisa&lt;/span&gt;&lt;span style=&quot; font-size:12pt; color:#000000;&quot;&gt; – A caring sister who supported Rizal during his exile and ensured the preservation of his works.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt; font-weight:600; color:#000000;&quot;&gt;4. Olimpia&lt;/span&gt;&lt;span style=&quot; font-size:12pt; color:#000000;&quot;&gt; – Known for her kind heart and joyful personality.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:12pt; font-weight:600; color:#000000;&quot;&gt;5. Lucia&lt;/span&gt;&lt;span style=&quot; font-size:12pt; color:#000000;&quot;&gt; – Supported Jose during challenging times and lived a quiet life.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
    </property>
   </widget>
   <widget class="QTextEdit" name="rizal_sib2">
    <property name="enabled">
     <bool>false</bool>
    </property>
    <property name="geometry">
     <rect>
      <x>570</x>
      <y>220</y>
      <width>401</width>
      <height>431</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">
    QTextEdit {
        background: transparent;
        font-family: &quot;Times New Roman&quot;;
        font-size: 10pt;
        border: none;
    }
</string>
    </property>
    <property name="html">
     <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Times New Roman'; font-size:10pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;6. Maria&lt;/span&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt; – Known for her love and close relationship with Jose.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt;7. &lt;/span&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;Jose&lt;/span&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt; – The seventh child and national hero of the Philippines.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt;8. &lt;/span&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;Concepcion&lt;/span&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt; – Tragically passed away at a young age, leaving Jose heartbroken. Her death deeply affected Rizal and sparked his early reflections on life and mortality.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt;9. &lt;/span&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;Josefa&lt;/span&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt; – Nicknamed “Panggoy,” she remained unmarried and actively supported Jose’s ideals.&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt;10. &lt;/span&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;Trinidad&lt;/span&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt; – Another strong supporter of Jose’s vision; she was entrusted with Jose’s last poem, &lt;/span&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;“Mi Último Adiós.”&lt;/span&gt;&lt;/p&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:12px; margin-bottom:12px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt;11. &lt;/span&gt;&lt;span style=&quot; font-size:11pt; font-weight:696; color:#000000;&quot;&gt;Soledad&lt;/span&gt;&lt;span style=&quot; font-size:11pt; color:#000000;&quot;&gt; – The youngest sibling, often referred to as “Choleng,” known for her strong-willed nature.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
    </property>
   </widget>
