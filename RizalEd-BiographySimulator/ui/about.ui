</string>
    </property>
    <property name="html">
     <string>&lt;!DOCTYPE HTML PUBLIC &quot;-//W3C//DTD HTML 4.0//EN&quot; &quot;http://www.w3.org/TR/REC-html40/strict.dtd&quot;&gt;
&lt;html&gt;&lt;head&gt;&lt;meta name=&quot;qrichtext&quot; content=&quot;1&quot; /&gt;&lt;style type=&quot;text/css&quot;&gt;
p, li { white-space: pre-wrap; }
&lt;/style&gt;&lt;/head&gt;&lt;body style=&quot; font-family:'Times New Roman'; font-size:10pt; font-weight:400; font-style:normal;&quot;&gt;
&lt;p align=&quot;justify&quot; style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-size:14pt; font-weight:600; color:#000000;&quot;&gt;RizalEd&lt;/span&gt;&lt;span style=&quot; font-size:14pt; color:#000000;&quot;&gt;: &lt;/span&gt;&lt;span style=&quot; font-size:14pt; font-weight:600; font-style:italic; color:#000000;&quot;&gt;Beyond the Pages&lt;/span&gt;&lt;span style=&quot; font-size:14pt; color:#000000;&quot;&gt; is a straightforward educational digital book designed to provide users with an accessible and interactive way to explore the life and legacy of &lt;/span&gt;&lt;span style=&quot; font-size:14pt; font-weight:600; color:#000000;&quot;&gt;José Rizal.&lt;/span&gt;&lt;span style=&quot; font-size:14pt; color:#000000;&quot;&gt; With this program, students, educators, and history enthusiasts can easily access key information about Rizal's childhood, education, advocacy, and his impact on Philippine history, all in one convenient place.&lt;/span&gt;&lt;/p&gt;&lt;/body&gt;&lt;/html&gt;</string>
    </property>
   </widget>
