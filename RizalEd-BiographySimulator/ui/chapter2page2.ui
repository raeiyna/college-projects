   <widget class="QTextEdit" name="ust2">
    <property name="enabled">
     <bool>false</bool>
    </property>
    <property name="geometry">
     <rect>
      <x>110</x>
      <y>210</y>
      <width>411</width>
      <height>551</height>
     </rect>
    </property>
    <property name="styleSheet">
     <string notr="true">
    QTextEdit {
        background: transparent;
        font-family: &quot;Times New Roman&quot;;
        font-size: 10pt;
