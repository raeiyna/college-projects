    font-family: &quot;Garamond&quot;, serif;
    font-size: 15px;
    color: #5c3d2e;
    padding: 5px;
    margin: 5px;
}

/* Scrollbars for vintage look */
QScrollBar:vertical, QScrollBar:horizontal {
    background: #f8f1e4; /* Match the background */
    border: 1px solid #8b6f47;
    width: 12px;
    height: 12px;
    margin: 3px;
}

QScrollBar::handle {
    background: #d9a66a; /* Same as button color */
    border-radius: 5px;
    min-height: 20px;
    min-width: 20px;
}

QScrollBar::handle:hover {
    background: #b57c4e; /* Darker amber on hover */
}

/* Placeholder text styling for input */
QLineEdit:placeholder {
    color: #a09383; /* Subtle gray-brown placeholder text */
    font-style: italic;
}</string>
