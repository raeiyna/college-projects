                <property name="styleSheet">
                 <string notr="true">/* Table Container Look */
QTableWidget {
    background-color: white;
    border: none;
    font-size: 14px;
    color: #212529;
    gridline-color: #f0f0f0;
    border-radius: 12px;
    outline: none;
    alternate-background-color: #fafafa;
}

/* Header Row */
QHeaderView::section {
    background-color: #006A71;  /* Soft peach like in image */
    color: white;
    font-weight: 600;
    font-size: 15px;
    padding: 10px;
    border: none;
    border-bottom: 1px solid #e2e2e2;
}

/* Table Rows */
QTableWidget::item {
    padding: 12px;
    border: none;
    border-bottom: 1px solid #eaeaea;
}

/* Hovered Item */
QTableWidget::item:hover {
    background-color: #f2f8ff;
}

/* Selected Item */
QTableWidget::item:selected {
    background-color: #e6f0fa;
    color: #000;
}

/* Remove gridline border from corner button */
QTableWidget QTableCornerButton::section {
    background-color: #fcdcc7;
    border: none;
}

/* Rounded scrollbar for modern look */
QScrollBar:vertical, QScrollBar:horizontal {
    border: none;
    background: transparent;
    margin: 2px;
    width: 8px;
    height: 8px;
}

QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #d0d0d0;
    border-radius: 4px;
}

QScrollBar::handle:hover {
    background: #a0a0a0;
}

QScrollBar::sub-line, QScrollBar::add-line {
    background: none;
    height: 0;
    width: 0;
}
</string>
