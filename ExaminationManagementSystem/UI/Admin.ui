           <property name="styleSheet">
            <string notr="true">QPushButton {
    color: white;  /* Text color */
    padding: 10px;
	font-size: 15px;
}

QPushButton:hover {
	border-radius: 10px;
    background: rgba(55, 163, 166, 0.5);  /* Slightly more visible on hover */
}

QPushButton:pressed {
    background: rgba(87, 204, 153, 0.7);  /* More intense when clicked */
}
</string>
