           <property name="text">
            <string/>
           </property>
           <property name="icon">
            <iconset>
             <normaloff>Resources/notification.png</normaloff>Resources/notification.png</iconset>
           </property>
           <property name="iconSize">
            <size>
             <width>40</width>
             <height>30</height>
            </size>
           </property>
