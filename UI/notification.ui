}

QListView::item:selected {
    background-color: #1F2B3A; /* Even darker background when an item is selected */
    color: white; /* White text when selected */
    font-size: 20px; /* Ensure selected item has the same font size */
    font-weight: bold; /* Bold font */
}

QListView::item:hover {
    background-color: #33415C; /* Slightly lighter dark color when hovering */
    color: white; /* White text when hovering */
    font-size: 20px; /* Ensure hovered item has the same font size */
    font-weight: bold; /* Bold font */
}

