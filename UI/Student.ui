                          <property name="styleSheet">
                           <string notr="true">QTabWidget::pane {
    border: none;
    background: transparent;
}

QTabBar::tab {
    background: #d4e8f4;
    color: #215988;
    font-size: 15px;                  /* Increased font size */
    font-weight: bold;
    padding: 10px 20px;               /* Increased padding */
    margin-right: 4px;                /* Slightly wider spacing */
    border-top-left-radius: 6px;
    border-top-right-radius: 6px;
    min-height: 10px;
	min-width: 80px;                 /* Minimum height to enlarge tab */
}

QTabBar::tab:selected {
    background: #3373B9;
    color: white;
    font-weight: bold;
}

QTabBar::tab:hover {
    background: #B8D5E7;
}
</string>
