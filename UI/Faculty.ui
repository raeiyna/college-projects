    padding: 5px;
    border: 2px solid #E5E5E5; /* Match background */
}

QListView::item {
    background-color: #0D7C66; /* Light blue for items */
    color: white; /* Darker blue text */
    font-size: 20px;
    font-family: Arial, Helvetica, sans-serif;
    border-radius: 8px;
    padding: 10px;
    margin: 5px 0;
}

QListView::item:selected {
    background-color: #007074  ; 
    font-size: 20px;
}

QListView::item:hover {
    background-color: #C1D8C3; /* Lighter blue on hover */
    color: #215988;
    font-size: 20px;
}

QListView::item:checked {
    background-color: #3C5A76; /* Darker shade for checked items */
    color: white;
    font-size: 20px;
}
</string>
