                      <widget class="QTabWidget" name="assigned_tab">
                       <property name="styleSheet">
                        <string notr="true">/* Keep the transparent content area */
QTabWidget::pane {
    border: none;
    background: transparent;
}

/* Tab buttons - normal */
QTabBar::tab {
    background: #d4e8f4;          /* Soft blue */
    color: #215988;               /* Deep blue text */
    font-size: 13px;
    font-weight: bold;
    padding: 6px 14px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

/* Selected tab */
QTabBar::tab:selected {
    background: #3373B9;          /* Bold blue */
    color: white;
    font-weight: bold;
}

/* Hovered tab */
QTabBar::tab:hover {
    background: #B8D5E7;          /* Light blue on hover */
}
</string>
