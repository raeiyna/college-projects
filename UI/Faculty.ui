                       <string notr="true">QCalendarWidget {
    background-color: black;
    color: white;
    border: none;
    font-family: 'Helvetica Neue', sans-serif;
    font-size: 16px;
}

QCalendarWidget QAbstractItemView {
    selection-background-color: #ff3b30;
    selection-color: white;
	border: none;
    background-color: black;
    gridline-color: #444;
}

QCalendarWidget QToolButton {
    color: white;
    font-size: 18px;
    icon-size: 24px, 24px;
    background: transparent;
    border: none;
}

QCalendarWidget QSpinBox {
    color: white;
    background: transparent;
    border: none;
}

QCalendarWidget QWidget#qt_calendar_navigationbar {
    background-color: black;
    border: none;
}

QCalendarWidget QAbstractItemView:enabled {
    color: white;
    background-color: black;
    selection-background-color: #ff3b30;
    selection-color: white;
}
/* Hover effect */
QCalendarWidget QAbstractItemView::item:hover {
    background-color: #555;  /* dark hover background */
    color: white;
    border-radius: 4px;
}

/* Current date highlight (uses QTextCharFormat from Python) */
QCalendarWidget QAbstractItemView::item:enabled:!selected[today=&quot;true&quot;] {
    border: 1px solid #ff3b30;
    font-weight: bold;
    color: #ff3b30;
    border-radius: 4px;
}
