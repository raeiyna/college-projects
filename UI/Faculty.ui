                         <item row="2" column="0">
                          <widget class="QListWidget" name="table_assigned_exam">
                           <property name="styleSheet">
                            <string notr="true">QListWidget {
    background-color: #E5E5E5; /* Light background color for the list view */
    border-radius: 10px; /* Rounded corners */
    padding: 5px;
    border: 2px solid #E5E5E5; /* Match background */
}

QListWidget::item {
    background-color: #0D7C66; /* Light blue for items */
    color: white; /* Darker blue text */
    font-size: 20px;
    font-family: Arial, Helvetica, sans-serif;
    border-radius: 8px;
    padding: 10px;
    margin: 5px 0;
}

QListWidget::item:selected {
    background-color: #007074; 
    font-size: 20px;
}

QListWidget::item:hover {
    background-color: #C1D8C3; /* Lighter blue on hover */
    color: #215988;
    font-size: 20px;
}

QListWidget::item:checked {
    background-color: #3C5A76; /* Darker shade for checked items */
    color: white;
    font-size: 20px;
}
</string>
