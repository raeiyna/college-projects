                        <layout class="QGridLayout" name="gridLayout_43">
                         <item row="1" column="0">
                          <widget class="QComboBox" name="exam_type_filter">
                           <property name="sizePolicy">
                            <sizepolicy hsizetype="Expanding" vsizetype="Fixed">
                             <horstretch>0</horstretch>
                             <verstretch>0</verstretch>
                            </sizepolicy>
                           </property>
                           <property name="styleSheet">
                            <string notr="true">QComboBox {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
                stop:0 #E9F3F0, stop:1 #D4EAE4);  /* Smooth gradient */
    color: #1B4D3E;                                /* Dark green text */
    border: 1px solid #BFD9CF;                     /* Softer border */
    border-radius: 8px;                            /* Rounded corners */
    padding: 8px 12px;                             /* Spacious padding */
    font: bold 13px &quot;Segoe UI&quot;;                     /* Sleek font */
    selection-background-color: #BFD9CF;            /* Highlight color */
    selection-color: #02281A;                      /* Selection text color */
    transition: background 0.3s ease;               /* Smooth transition */
}

QComboBox:hover {
    background: #D4EAE4;                           /* Softer hover effect */
    border: 1px solid #A3C9B9;                     /* Subtle border change */                              /* Wider dropdown button */
}

QComboBox QAbstractItemView {
    background: #E9F3F0;                           /* Light dropdown background */
    color: #1B4D3E;                                /* Dark green text */
    border: 1px solid #BFD9CF;
    border-radius: 8px;                            /* Rounded corners */
    selection-background-color: #BFD9CF;            /* Selection color */
    selection-color: #02281A;                      /* Selection text color */
    padding: 4px;                                  /* Space around items */
}
</string>
                           </property>
